# ==========================================
# FILE CẤU HÌNH MẪU CHO MÔI TRƯỜNG DEV
# Hướng dẫn: Copy file này, đổi tên thành .env và điền các giá trị thực tế
# KHÔNG BAO GIỜ PUSH FILE .env LÊN GIT!
# ==========================================

# 1. DATABASE (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/TechStoreManager
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# 2. JWT (JSON Web Token)
# Secret key dùng để mã hóa token (Cần chuỗi ngẫu nhiên, độ dài tối thiểu 256-bit)
JWT_SECRET=your_jwt_secret_key_here
# Thời gian sống của Access Token (tính bằng giây, mặc định 3600s = 1 giờ)
JWT_EXPIRATION=3600
# Thời gian sống của Refresh Token (tính bằng giây, mặc định 604800s = 7 ngày)
JWT_REFRESH_EXPIRATION=604800

# 3. OAUTH2 (Đăng nhập Google / Facebook)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Lấy từ Facebook Developer
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# 4. MAIL CONFIGURATION (Gửi email)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_google_app_password

# 5. CLOUDINARY (Lưu trữ hình ảnh)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# 6. GEMINI AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent

# 7. GOSHIP (Giao hàng)
GOSHIP_API_TOKEN=your_goship_jwt_token_here

# 8. VNPAY (Thanh toán)
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
# URL để VNPAY redirect về sau khi thanh toán xong (Dùng ngrok khi test ở local)
VNPAY_RETURN_URL=http://localhost:8080/api/public/orders/vnpay-callback

# 9. ADMIN ACCOUNT (Tài khoản khởi tạo mặc định)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_USERNAME=admin
ADMIN_PHONE=0123456789